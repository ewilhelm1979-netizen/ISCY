DEBUG=False
SECRET_KEY=replace-me-stage-secret
ALLOWED_HOSTS=stage.localhost,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://stage.localhost,http://127.0.0.1:8080
USE_X_FORWARDED_HOST=True
TRUST_X_FORWARDED_PROTO=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
DATABASE_URL=postgresql://isms:isms@db:5432/isms
POSTGRES_DB=isms
POSTGRES_USER=isms
POSTGRES_PASSWORD=change-me
RUN_MIGRATIONS=1
RUN_SEEDS=0
RUN_COLLECTSTATIC=1
APP_SERVER=gunicorn
NGINX_HOST=stage.localhost
NGINX_CLIENT_MAX_BODY_SIZE=50m
NGINX_PROXY_READ_TIMEOUT=300
LOCAL_LLM_ENABLED=False
