DATABASE_URL=postgresql://isms:change-me@db:5432/isms
RUST_BACKEND_BIND=0.0.0.0:9000
RUST_BACKEND_URL=http://app:9000
ISCY_MEDIA_ROOT=/app/media
ISCY_APP_MODE=demo
ISCY_TRUST_PROXY_IDENTITY_HEADERS=1
ISCY_TRUSTED_PROXY_CONFIGURED=1
ISCY_SECURE_COOKIES=1
ISCY_HTTPS_CONFIRMED=1
ISCY_HSTS_ENABLED=0
ISCY_ALERTMANAGER_TOKEN=
ISCY_ALERTMANAGER_TOKEN_FILE=/run/secrets/iscy-alertmanager-token
ISCY_ALERTMANAGER_HMAC_SECRET=
ISCY_ALERTMANAGER_HMAC_SECRET_FILE=/run/secrets/iscy-alertmanager-hmac
ISCY_ALERTMANAGER_HMAC_PREVIOUS_SECRET=
ISCY_ALERTMANAGER_HMAC_PREVIOUS_SECRET_FILE=
ISCY_ALERTMANAGER_HMAC_MAX_AGE_SECONDS=300
ISCY_INITIAL_ADMIN_TENANT_NAME=ISCY Stage Tenant
ISCY_INITIAL_ADMIN_TENANT_SLUG=iscy-stage
ISCY_INITIAL_ADMIN_USERNAME=iscy-admin
ISCY_INITIAL_ADMIN_EMAIL=iscy-admin@example.local
ISCY_INITIAL_ADMIN_FIRST_NAME=ISCY
ISCY_INITIAL_ADMIN_LAST_NAME=Admin
ISCY_INITIAL_ADMIN_PASSWORD=
ISCY_INITIAL_ADMIN_PASSWORD_FILE=/run/secrets/iscy-initial-admin-password

POSTGRES_DB=isms
POSTGRES_USER=isms
POSTGRES_PASSWORD=change-me

NGINX_HOST=stage.localhost
NGINX_CLIENT_MAX_BODY_SIZE=50m
NGINX_PROXY_READ_TIMEOUT=300

NVD_API_BASE_URL=https://services.nvd.nist.gov
NVD_API_KEY=

LOCAL_LLM_MODEL_NAME=iscy-rust-llm
LOCAL_LLM_N_CTX=8192
LOCAL_LLM_N_THREADS=8
LOCAL_LLM_GPU_LAYERS=0
